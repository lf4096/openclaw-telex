{
	"name": "openclaw-telex",
	"version": "1.0.1",
	"description": "OpenClaw Telex channel plugin",
	"type": "module",
	"main": "./dist/index.js",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lf4096/openclaw-telex.git"
	},
	"homepage": "https://github.com/lf4096/openclaw-telex#readme",
	"bugs": "https://github.com/lf4096/openclaw-telex/issues",
	"keywords": ["openclaw", "telex", "voyager", "chatbot", "channel-plugin"],
	"engines": {
		"node": ">=22.16.0"
	},
	"files": ["dist/**/*.js", "openclaw.plugin.json", "CHANGELOG.md"],
	"scripts": {
		"build": "tsup",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --fix .",
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@sinclair/typebox": "0.34.48",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^22.16.0",
		"openclaw": "2026.6.1",
		"tsup": "^8.3.0",
		"typescript": "^5.6.0"
	},
	"peerDependencies": {
		"openclaw": ">=2026.6.1"
	},
	"peerDependenciesMeta": {
		"openclaw": {
			"optional": true
		}
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome"]
	},
	"openclaw": {
		"extensions": ["./dist/index.js"],
		"setupEntry": "./dist/setup-entry.js",
		"channel": {
			"id": "telex",
			"label": "Telex",
			"selectionLabel": "Telex (plugin)",
			"blurb": "Voyager Telex messaging integration",
			"order": 75,
			"quickstartAllowFrom": true
		},
		"install": {
			"clawhubSpec": "openclaw-telex",
			"npmSpec": "openclaw-telex",
			"defaultChoice": "npm"
		},
		"compat": {
			"pluginApi": ">=2026.6.1"
		},
		"build": {
			"openclawVersion": "2026.6.1",
			"pluginSdkVersion": "2026.6.1"
		},
		"release": {
			"publishToNpm": true,
			"publishToClawHub": true
		}
	}
}
